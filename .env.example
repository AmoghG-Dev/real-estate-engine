# Root .env – copy to each service and customise

# ── ML Service ─────────────────────────────
ML_PORT=5001
ML_API_KEY=dev-secret-key
FLASK_DEBUG=false

# ── Node.js API Gateway ────────────────────
PORT=4000
ML_SERVICE_URL=http://localhost:5001
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000

# ── React Frontend ─────────────────────────
REACT_APP_API_URL=http://localhost:4000/api
